{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vp: check",
      "type": "shell",
      "command": "vp check",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": {
        "owner": "vp",
        "source": "vp",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^x\\s+([^\\(]+)\\(([^\\)]+)\\):\\s+(.*)$",
            "code": 2,
            "message": 3
          },
          {
            "regexp": "^\\s*,?-\\[([^:]+):(\\d+):(\\d+)\\]",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ]
      }
    },
    {
      "label": "vp: dev",
      "type": "shell",
      "command": "vp dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vp",
        "source": "vp",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^x\\s+([^\\(]+)\\(([^\\)]+)\\):\\s+(.*)$",
            "code": 2,
            "message": 3
          },
          {
            "regexp": "^\\s*,?-\\[([^:]+):(\\d+):(\\d+)\\]",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*VITE\\+ v",
          "endsPattern": "^\\s*➜\\s+Local:\\s+http://"
        }
      }
    },
    {
      "label": "vp: build",
      "type": "shell",
      "command": "vp build",
      "group": "build",
      "problemMatcher": {
        "owner": "vp",
        "source": "vp",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^x\\s+([^\\(]+)\\(([^\\)]+)\\):\\s+(.*)$",
            "code": 2,
            "message": 3
          },
          {
            "regexp": "^\\s*,?-\\[([^:]+):(\\d+):(\\d+)\\]",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ]
      }
    }
  ]
}
